generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model feedback_analysis {
  id                        String          @id
  outletId                  BigInt?
  bookingId                 String?
  recordingURL              String?
  transcription             Json?
  translation               Json?
  translation_usage         Json?
  audio_metadata            String?
  is_processed              Boolean?
  is_sent                   Boolean?
  client_response           String?
  created_at                DateTime?       @db.Timestamptz(6)
  updated_at                DateTime?       @db.Timestamptz(6)
  csat_scorecard            Json?
  overall_experience_rating String?
  special_mentions          String?
  summary                   String?
  transcript                String?
  outletName                String?
  issue_tickets             issue_tickets[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model issue_tickets {
  id                 String             @id
  ticket_type        String?
  category           String?
  subcategory        String?
  severity           String?
  description        String?
  created_at         DateTime?          @db.Timestamptz(6)
  updated_at         DateTime?          @db.Timestamptz(6)
  feedbackAnalysisId String?
  feedback_analysis  feedback_analysis? @relation(fields: [feedbackAnalysisId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
